# --- Database Configuration ---
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpasswd
POSTGRES_DB=transcendence

# --- Proxy Configuartion ---
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
TLS_CERT_FILE=transcendence-selfsigned.crt
TLS_KEY_FILE=transcendence-selfsigned.key
# add your machines local ip or domain here. seperate multiple hosts with comma. e.g. localhost,127.0.0.1,172.17.10.2
TLS_CERT_HOSTS=localhost,127.0.0.1
APP_ORIGIN=https://localhost

# --- Backend Configuration ---
BACKEND_PORT=3001
FILES_DIR=/data/uploads
AVATAR_MAX_FILE_SIZE_BYTES=2097152
POST_IMAGE_MAX_FILE_SIZE_BYTES=5242880
DEFAULT_AVATAR_FILENAME=default.svg
FRONTEND_ORIGIN=http://localhost:3000
# add your machines local ip or domain here. seperate multiple origins with comma. e.g. http://localhost,https://172.17.10.2
# If you changed the proxy ports, make sure to update the origins with the correct ports as well. e.g. https://localhost:8443,https://172.17.10.2:8443
CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:3000
TRUST_PROXY_HOPS=1
COOKIE_SECURE_MODE=auto
COOKIE_SAME_SITE=lax
DATABASE_URL=postgresql://dbuser:dbpasswd@db:5432/transcendence?schema=public
#create JWT_SECRET with '$openssl rand -hex 64'
JWT_SECRET=transcendence42
JWT_ISSUER=transcendence
JWT_AUDIENCE=transcendence_client
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- Frontend Configuration ---
FRONTEND_PORT=3000

# --- OAuth Configuration---

# --- Blockchain Configuration ---